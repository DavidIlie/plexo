# Plex server
PLEX_URL=https://plex.davidhome.ro
PLEX_TOKEN=

# Tautulli
TAUTULLI_URL=https://tautulli.davidhome.ro
TAUTULLI_API_KEY=
# Optional: scope Tautulli stats to a specific user (leave empty for all users)
TAUTULLI_USER_ID=

# Admin
REFRESH_SECRET=
DISPLAY_NAME=David

# Base URL where the app is hosted
APP_URL=http://localhost:3000
# Displayed footer build/version identifier. Docker builds set this to the Git commit hash.
NEXT_PUBLIC_VERSION=dev

# Plausible analytics (optional)
PLAUSIBLE_ENABLED=false
PLAUSIBLE_DOMAIN=
# For self-hosted Plausible:
PLAUSIBLE_SCRIPT_URL=
PLAUSIBLE_API_URL=

# Privacy controls
SHOW_DEVICES=true
SHOW_LOCATIONS=false

# Music library
SHOW_MUSIC=false

# Recommendations (optional)
RECOMMEND_ENABLED=false
TMDB_API_KEY=
# Cloudflare Turnstile (optional captcha)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Notification channels (at least one required for recommendations)
RESEND_API_KEY=
RESEND_FROM="Plexo <noreply@yourdomain.com>"
RECOMMEND_EMAIL_TO=
# SMTP (alternative to Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Discord webhook
DISCORD_WEBHOOK_URL=
# Overseerr (optional, for request management + dashboard wishlist)
OVERSEERR_URL=
OVERSEERR_API_KEY=
# Auto-create Overseerr request when someone recommends (default: false)
RECOMMEND_AUTO_REQUEST=false

# Image proxy optimization
# IMAGE_OPTIMIZE: when true, re-encode Plex images to WebP via sharp.
# Pros: smaller payloads, faster loads. Cons: ~30MB sharp binary, CPU per image.
IMAGE_OPTIMIZE=true
# WebP quality, 1-100. Higher = sharper + larger. 85 is a sweet spot.
IMAGE_OPTIMIZE_QUALITY=85
# Multiplier for the resolution we fetch from Plex before sharp downsamples.
# 2 = pull 2x the requested size from Plex so the downsample produces sharper
# results (vs. asking Plex to deliver exactly the display size). Set to 1 to
# skip super-sampling if CPU/bandwidth is a concern.
IMAGE_UPSTREAM_SCALE=2
